{
  "name": "duel",
  "version": "1.0.0",
  "description": "Duel simulation",
  "license": "ISC",
  "author": "demesup",
  "type": "commonjs",
  "main": "dist/cli.js",
  "scripts": {
      "build": "tsc",
      "duel": "node dist/cli.js",
